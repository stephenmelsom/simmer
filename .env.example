# Public URL the app is served on (behind Caddy). OIDC redirect URI is
# derived from this: ${BASE_URL}/auth/callback
BASE_URL=https://themelsoms.com

# Pocket ID — Admin → OIDC Clients → new client, PKCE enabled.
# Enable the "groups" scope/claim for this client.
OIDC_ISSUER=https://auth.themelsoms.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Session cookie signing key — generate with: openssl rand -base64 48
SESSION_SECRET=

# ——— Local development only ———
# AUTH_MODE=disabled skips Pocket ID and fakes a session:
# AUTH_MODE=disabled
# DEV_USER=Developer
# DEV_GROUPS=admins,adults
